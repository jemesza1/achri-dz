# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# JWT_SECRET: Secret used to sign user session tokens (login cookies).
# REQUIRED in production — generate a long random value, e.g. with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Without it, the server falls back to an insecure dev-only secret.
JWT_SECRET="MY_JWT_SECRET"

# GOOGLE_CLIENT_ID: OAuth 2.0 Client ID from Google Cloud Console
# (console.cloud.google.com → APIs & Services → Credentials → Create
# OAuth client ID → Web application). Add your site's URL under
# "Authorized JavaScript origins". Free. Without it, the "Sign in with
# Google" button is hidden and /api/auth/google returns 503.
GOOGLE_CLIENT_ID="MY_GOOGLE_CLIENT_ID.apps.googleusercontent.com"

# SMTP_*: Used to send the email verification link on signup.
# Without these, the verification link is just logged to the server
# console instead of emailed — fine for local dev, NOT fine for production.
# Example with Gmail: create an "App password" at myaccount.google.com/apppasswords
# (requires 2-Step Verification enabled on the Google account).
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-address@gmail.com"
SMTP_PASS="MY_SMTP_APP_PASSWORD"
SMTP_FROM="Achri DZ <your-address@gmail.com>"

# TWILIO_*: Used to send the SMS verification code for phone confirmation.
# Without these, the code is just logged to the server console instead of
# sent by SMS — fine for local dev, NOT fine for production. Create a
# trial/paid account at twilio.com (paid SMS sending, has a free trial credit).
TWILIO_ACCOUNT_SID="MY_TWILIO_ACCOUNT_SID"
TWILIO_AUTH_TOKEN="MY_TWILIO_AUTH_TOKEN"
TWILIO_FROM_NUMBER="+15555550100"
